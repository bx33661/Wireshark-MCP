---
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>404 | Wireshark MCP</title>
    <style>
      :root {
        color-scheme: light dark;
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: #f8fbfb;
        color: #102124;
      }

      body {
        display: grid;
        min-height: 100vh;
        margin: 0;
        place-items: center;
      }

      main {
        width: min(32rem, calc(100vw - 2rem));
      }

      h1 {
        margin: 0 0 0.75rem;
        color: #007c89;
        font-size: 3rem;
      }

      p {
        margin: 0 0 1.5rem;
        line-height: 1.6;
      }

      a {
        color: #007c89;
        font-weight: 700;
      }

      @media (prefers-color-scheme: dark) {
        :root {
          background: #07191c;
          color: #d6eeee;
        }

        h1,
        a {
          color: #33d6c2;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <h1>404</h1>
      <p>Page not found. Check the URL or return to the Wireshark MCP docs.</p>
      <a href="/">Back to docs</a>
    </main>
  </body>
</html>
